{
  "expo": {
    "name": "Iskra",
    "slug": "iskra-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iskra-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FDFCFA"
    },
    "scheme": "iskra",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.iskraclub.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.iskraclub.app",
      "adaptiveIcon": {
        "backgroundColor": "#E8621A"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/iskra-logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/iskra-flame-white.png",
          "color": "#E8621A"
        }
      ],
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be0a7d2b-d3a4-4b2d-a12c-c3fa41387774"
      }
    },
    "owner": "zenithdigital"
  }
}
